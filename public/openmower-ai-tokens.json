{
  "_instructions": [
    "This file describes the OpenMower design system for AI consumption.",
    "When styling components, use these tokens to match the brand identity.",
    "The system is built on Material UI v6 with a dark-mode graphite + green theme.",
    "Primary interactive color: #2CC76B (Mow Green) with white text.",
    "Amber accent (decorative / status): #F5A523.",
    "Always use DM Sans for UI text and DM Mono for code/monospace."
  ],
  "name": "OpenMower",
  "description": "Light-mode design system for the OpenMower open-source RTK GPS robotic lawn mower project.",
  "version": "1.1.0",
  "mode": "light",
  "colors": {
    "accent": {
      "green": "#2CC76B",
      "greenDeep": "#1EA856",
      "greenLight": "#3DD97E",
      "greenPale": "#E3F9EC",
      "amber": "#F5A523",
      "usage": "Brand accent — tab indicators, section labels, decorative highlights"
    },
    "primary": {
      "main": "#1B9D52",
      "light": "#2CC76B",
      "dark": "#14853F",
      "contrastText": "#ffffff",
      "usage": "Interactive primary — buttons, links, focus rings, active states"
    },
    "secondary": {
      "main": "#14853F",
      "contrastText": "#ffffff",
      "usage": "Secondary actions — darker mow green, visually subordinate to primary"
    },
    "background": {
      "default": "#FFFFFF",
      "paper": "#FFFFFF",
      "surface2": "#EFEFEF",
      "surface3": "#E5E5E5",
      "usage": "Layered light surfaces — default → paper → card → elevated card"
    },
    "border": {
      "subtle": "#E0E0E0",
      "default": "#CACACA",
      "usage": "Dividers, card borders, input outlines"
    },
    "text": {
      "primary": "#1A1A1A",
      "secondary": "#555555",
      "disabled": "#9E9E9E",
      "usage": "Graphite text hierarchy — primary for headings, secondary for body, disabled for metadata"
    },
    "semantic": {
      "error": "#C93020",
      "warning": "#F5A523",
      "info": "#1565C0",
      "success": "#1B9D52"
    }
  },
  "typography": {
    "fontFamily": "DM Sans Variable",
    "monoFamily": "DM Mono",
    "weights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "scale": {
      "display": {
        "size": "60px",
        "weight": 700,
        "letterSpacing": "-0.03em",
        "lineHeight": 1
      },
      "h1": {
        "size": "42px",
        "weight": 600,
        "letterSpacing": "-0.02em",
        "lineHeight": 1.1
      },
      "h2": {
        "size": "30px",
        "weight": 600,
        "letterSpacing": "-0.01em",
        "lineHeight": 1.2
      },
      "h3": {
        "size": "22px",
        "weight": 600,
        "letterSpacing": "0",
        "lineHeight": 1.3
      },
      "h4": {
        "size": "18px",
        "weight": 600,
        "letterSpacing": "0",
        "lineHeight": 1.4
      },
      "h5": {
        "size": "16px",
        "weight": 600,
        "letterSpacing": "0",
        "lineHeight": 1.5
      },
      "h6": {
        "size": "14px",
        "weight": 600,
        "letterSpacing": "0",
        "lineHeight": 1.5
      },
      "body1": {
        "size": "16px",
        "weight": 400,
        "letterSpacing": "0",
        "lineHeight": 1.7
      },
      "body2": {
        "size": "14px",
        "weight": 400,
        "letterSpacing": "0",
        "lineHeight": 1.6
      },
      "caption": {
        "size": "11px",
        "weight": 500,
        "letterSpacing": "0.08em",
        "lineHeight": 1.5
      },
      "overline": {
        "size": "11px",
        "weight": 600,
        "letterSpacing": "0.14em",
        "lineHeight": 2,
        "transform": "uppercase"
      },
      "button": {
        "size": "15px",
        "weight": 500,
        "letterSpacing": "0.01em",
        "transform": "none"
      },
      "code": {
        "family": "DM Mono",
        "size": "14px",
        "color": "#F5A523"
      }
    }
  },
  "shape": {
    "borderRadius": 12,
    "borderRadiusSm": 6,
    "borderRadiusMd": 8,
    "borderRadiusLg": 16
  },
  "spacing": {
    "unit": 8,
    "note": "All spacing is a multiple of 8px — xs=4, sm=8, md=16, lg=24, xl=32, xxl=48"
  },
  "components": {
    "button": {
      "contained": "Green 500→700 gradient (135°), white text, no shadow, border-radius 8px",
      "outlined": "1.5px green border, transparent bg, green text",
      "text": "No border, green text, subtle green hover tint",
      "ghost": "Surface3 background, default text, border2 border → green border on hover",
      "danger": "rgba(255,70,70,0.10) bg, #FF6040 text, rgba(255,70,70,0.20) border",
      "sizes": {
        "small": "7px 15px / 13px",
        "medium": "10px 22px / 15px",
        "large": "14px 30px / 17px"
      }
    },
    "chip": {
      "primary": "rgba(76,175,80,0.14) bg, #4CAF50 text, border-radius 20px",
      "secondary": "rgba(245,165,35,0.12) bg, #F5A523 text"
    },
    "card": {
      "background": "surface2 (#EFEFEF)",
      "border": "1px solid border (#E0E0E0)",
      "borderRadius": "12px",
      "padding": "20px 22px"
    },
    "input": {
      "background": "surface2",
      "border": "border2 (#424A47) → primary on focus",
      "borderRadius": "8px"
    },
    "alert": {
      "borderRadius": "10px",
      "border": "1px solid semantic color at 25% opacity",
      "background": "semantic color at 8-10% opacity"
    }
  },
  "themeFactory": {
    "_note": "Use this section with the anthropic-skills:theme-factory skill",
    "name": "OpenMower Light",
    "mode": "light",
    "primaryColor": "#1B9D52",
    "primaryColorLight": "#2CC76B",
    "primaryColorDark": "#14853F",
    "accentColor": "#2CC76B",
    "secondaryColor": "#F5A523",
    "backgroundColor": "#FFFFFF",
    "surfaceColor": "#FFFFFF",
    "textColor": "#1A1A1A",
    "textSecondaryColor": "#555555",
    "errorColor": "#C93020",
    "warningColor": "#F5A523",
    "infoColor": "#1565C0",
    "successColor": "#1B9D52",
    "headingFont": "DM Sans Variable",
    "bodyFont": "DM Sans Variable",
    "monoFont": "DM Mono",
    "borderRadius": "12px"
  },
  "cssVariables": {
    "--color-primary": "#1B9D52",
    "--color-primary-light": "#2CC76B",
    "--color-primary-dark": "#14853F",
    "--color-accent": "#2CC76B",
    "--color-amber": "#F5A523",
    "--color-bg": "#FFFFFF",
    "--color-surface": "#FFFFFF",
    "--color-surface-2": "#EFEFEF",
    "--color-surface-3": "#E5E5E5",
    "--color-border": "#E0E0E0",
    "--color-border-2": "#CACACA",
    "--color-text": "#1A1A1A",
    "--color-text-secondary": "#555555",
    "--color-text-disabled": "#9E9E9E",
    "--color-error": "#C93020",
    "--color-warning": "#F5A523",
    "--color-info": "#1565C0",
    "--color-success": "#1B9D52",
    "--font-sans": "\"DM Sans Variable\", sans-serif",
    "--font-mono": "\"DM Mono\", monospace",
    "--radius": "12px"
  },
  "tailwindConfig": {
    "_note": "Paste into tailwind.config.js → theme.extend",
    "colors": {
      "primary": {
        "DEFAULT": "#1B9D52",
        "light": "#2CC76B",
        "dark": "#14853F"
      },
      "accent": "#2CC76B",
      "amber": "#F5A523",
      "bg": "#FFFFFF",
      "surface": "#FFFFFF",
      "surface-2": "#EFEFEF",
      "surface-3": "#E5E5E5",
      "border": "#E0E0E0",
      "border-2": "#CACACA",
      "error": "#C93020",
      "warning": "#F5A523",
      "info": "#1565C0",
      "success": "#1B9D52"
    },
    "fontFamily": {
      "sans": [
        "\"DM Sans Variable\"",
        "sans-serif"
      ],
      "mono": [
        "\"DM Mono\"",
        "monospace"
      ]
    },
    "borderRadius": {
      "brand": "12px"
    }
  },
  "muiUsage": {
    "_note": "Minimal snippet to apply this theme in a React + MUI project",
    "install": "npm install @mui/material @emotion/react @emotion/styled",
    "snippet": [
      "import { ThemeProvider } from '@mui/material/styles'",
      "import CssBaseline from '@mui/material/CssBaseline'",
      "import { openMowerTheme } from './theme'  // copy src/theme/ into your project",
      "",
      "export default function App() {",
      "  return (",
      "    <ThemeProvider theme={openMowerTheme}>",
      "      <CssBaseline />",
      "      {/* your app */}",
      "    </ThemeProvider>",
      "  )",
      "}"
    ]
  }
}